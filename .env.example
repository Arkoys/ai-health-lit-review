# API Keys for Literature Review System

# Google Gemini AI Studio (2M tokens/month FREE) - REQUIRED
GEMINI_API_KEY=AIzaSy...

# HuggingFace Inference API (30K tokens/month FREE) - OPTIONAL but recommended
HUGGINGFACE_API_KEY=hf_...

# OpenRouter (StepFun etc.) - OPTIONAL fallback
OPENROUTER_API_KEY=sk-or-...

# Email (SMTP) configuration - OPTIONAL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Telegram Bot - OPTIONAL
TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Optional: specific chat/channel ID (if not set, uses config channel_id)
TELEGRAM_CHAT_ID=-100xxxxxxxxxx

# Google Drive API (Service Account) - OPTIONAL for cumulative Google Doc
GOOGLE_CREDENTIALS_JSON={
  "type": "service_account",
  "project_id": "...",
  "private_key_id": "...",
  ...
}
# Or path to credentials file: GOOGLE_CREDENTIALS_PATH=/path/to/credentials.json